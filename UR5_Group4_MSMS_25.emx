     connections
      FlowSensor1\flow -> Integrate\input;
      FlowSensor1\p2 => ZeroJunction\p;
      Integrate\R_theta_v -> R_theta_transpose\R_theta;
      Integrate\R_theta_w -> R_theta_trans1\R_theta;
      Integrate\theta_out -> theta_out;
      PowerDemux2\output1 => ZeroJunction1\p;
      PowerDemux2\output2 => ZeroJunction2\p;
      PowerDemux2\output3 => ZeroJunction\p;
      PowerMux1\output => R_theta_trans1\p1;
      R_theta_trans1\p2 => w_out;
      R_theta_transpose\p2 => v_out;
      theta_dot => FlowSensor1\p1;
      v_in |=> ZeroJunction4\p user;
      w_in => PowerDemux2\input;
      ZeroJunction\p => PowerMux1\input3;
      ZeroJunction1\p => C_wx\input;
      ZeroJunction1\p => PowerMux1\input1;
      ZeroJunction2\p => C_wy\input;
      ZeroJunction2\p => PowerMux1\input2;
      ZeroJunction4\p => R_theta_transpose\p1;
      ZeroJunction4\p |=> C_v\input user;
     end;
    implementation_end;
   Link_1 248 112
    description '<Information><Description><Version>4.0</Version><LibraryPath>Template\Submodel-Graphical.emx</LibraryPath><IsMainModel>1</IsMainModel><KeepParameterValues>True</KeepParameterValues><TimeStamp>2007-11-1 22:32:34</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description><Attributes><GlobalRelations>parameters
	real m = 3.7; 
	real J[3,3] = [0.0067, 		0.0,			0.0;
					   0.0, 	   	0.0064,   	0.0; 
					   0.0, 	    	0.0,	 	   0.00676];
	real rG[3] = [0; -0.02561; 0.00193]; 

	real global alpha_DH[6];
	real global d_DH[6];
	real global a_DH[6];


variables 
	//DENAVIT-HARTENBERG
	real a ;
	real alpha; 
	real d;

initialequations
	alpha = alpha_DH[1]; 
	a = a_DH[1];
	d = d_DH[1];</GlobalRelations></Attributes></Information>';
    type 'Submodel-Graphical'
     ports
      power in w_A [3,1];
      power in v_A [3,1];
      power out w_B [3,1];
      power out v_B [3,1];
    end;
    implementation bg
     submodels
      Euler_EQ 560 390
       description '<Information><Description><Version>4.0</Version><LibraryPath>Template\Submodel-Equation.emx</LibraryPath><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><TimeStamp>2007-11-1 22:32:1</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description></Information>';
       type 'Submodel-Equation'
        ports
         power in Tran [3,1];
         power in Rot [3,1];
         signal out R_OG [3,3];
         signal out P_OG [3,1];
         signal out p_og_anim [3,1];
       end;
       implementation eq
parameters
	real global m;
	real global J[3, 3];
	real global rG[3, 1];
	
variables
	real omega[3,1], v[3,1];
	real p[3,1], h[3,1]; 
	real R_OG_0[3,3];
	real P_OG_0[3,1];
		
	real global H1[4,4];
		
initialequations
	R_OG_0 = H1[1:3,1:3];
	P_OG_0 = R_OG_0*rG + H1[1:3,4]; 
/* Position vector of point G relative to origin O in reference frame 0
 R_OG_0 * rG rotates the CoM position from link frame to base frame
 H1[1:3,4] gives the origin of the link frame in the base frame
 Their sum gives the absolute position of G in base frame 0 (P_OG_0)*/
equations 
	omega = Rot.f; 
	v = Tran.f; 
	//Euler equations
	p = int(Tran.e - skew(omega)*p); 
	h = int(Rot.e - skew(omega)*h);
	
	//R_OG & P_OG
	R_OG = int(R_OG * skew(omega), R_OG_0);
	P_OG = int(R_OG * v, P_OG_0); 
	p_og_anim = P_OG * 5;
	
	
	Tran.f = p/m; 
	Rot.f = inverse(J)*h; 
	
implementation_end;
      gravity 256 400
       description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\3D\Se-3.emx</LibraryPath><TimeStamp>2007-9-25 12:11:25</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type 'Se-3'
        ports
         power out p [3,1];
        restrictions
         causality fixed out p;
       end;
       icon bg ellipse bottom
        figures
         text 'Se' 256 400 color 0 18 bold;
       end;
       implementation eq
parameters 
	real global m;
	real global gravity_yes;
variables
	real flow [3,1];
	real effort[3,1];


initialequations
	if gravity_yes == 1 then 
		effort= [0.0; 0.0; -m * 9.81];
	else
		effort= [0.0; 0.0; 0.0];
	end;

equations
	p.e = effort; 
	flow = p.f;implementation_end;
