   G_Compensation 576 496
    description '<Information><Description><Version>4.0</Version><LibraryPath>Template\Submodel-Equation.emx</LibraryPath><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><TimeStamp>2007-11-1 22:32:1</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description></Information>';
    type 'Submodel-Equation'
     ports
      signal in q2;
      signal in q3;
      signal in q4;
      signal in q5;
      signal out gc2;
      signal out gc3;
      signal out gc4;
      signal out gc5;
    end;
    implementation eq
// Calculated using the sympy library with the python script attached
equations	
	gc2 = -0.329402533419*sin(q5)*cos(q2 + q3 + q4) + 1.37619581076*sin(q2 + q3 + q4) - 37.34897535*cos(q2) - 14.89429565325*cos(q2 + q3);
	gc3 = -0.329402533419*sin(q5)*cos(q2 + q3 + q4) + 1.37619581076*sin(q2 + q3 + q4) - 14.89429565325*cos(q2 + q3);
	gc4 = -0.329402533419*sin(q5)*cos(q2 + q3 + q4) + 1.37619581076*sin(q2 + q3 + q4);
	gc5 = -0.329402533419*sin(q2 + q3 + q4)*cos(q5);
	implementation_end;
