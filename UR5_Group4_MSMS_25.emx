	real r[3,3];

initialequations 
	
	r_GB = [-rG[1]; 
          -rG[2]; 
          -rG[3]];
	
	r = skew(r_GB);
	
equations					
	p1.f = (r) * p2.f;
	p2.e = transpose(r) * p1.e;
implementation_end;
