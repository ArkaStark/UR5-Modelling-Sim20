      B_f 400 32
       description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\R.emx</LibraryPath><TimeStamp>2011-11-29 16:35:37</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type R
        ports
         power in p;
       end;
       icon bg ellipse right
        figures
         text 'R' 400 32 color 0 18 bold;
       end;
       implementation eq
parameters
	real Bmw=0.00064;
	real Bplus=0.008;
	real Bminus=-0.007;
variables
	real r;


equations
	if (p.f)>=0 then 
		r = Bmw*p.f+Bplus;
	else
		r=Bmw*p.f+Bminus;
	end;
	
	p.e = r;
implementation_end;
      B_mw 152 32
       description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\R.emx</LibraryPath><TimeStamp>2011-11-29 16:35:37</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type R
