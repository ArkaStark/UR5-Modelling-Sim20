implementation_end;
      J_mw 112 32
       description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\I.emx</LibraryPath><TimeStamp>2011-11-29 15:55:55</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type I
        ports
         power in p;
         signal out state;
        restrictions
         causality preferred in p;
       end;
       icon bg ellipse left
        figures
         text 'I' 112 32 color 0 18 bold;
       end;
       implementation eq
parameters
	real i = 0.0000404;
equations
    state = int(p.e);
    p.f = state / i;
implementation_end;
      K_f 352 152
       description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\C.emx</LibraryPath><TimeStamp>2011-11-29 15:58:35</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type C
        ports
         power in p;
         signal out state;
        restrictions
         causality preferred out p;
       end;
       icon bg ellipse bottom
        figures
         text 'C' 352 152 color 0 18 bold;
       end;
       implementation eq
parameters
	real k_1 = 16000;
	real k_2 = 25000;
	real k_3 = 29000;
	real T_1 = 7;
	real T_2 = 25;
	
variables
	real phi_1;
	real phi_2;
	real theta;	

equations
	phi_1 = T_1/k_1;
	phi_2 = phi_1 + (T_2-T_1)/k_2;
	theta = int(p.f);
	
	if abs(theta)<phi_1 then
		p.e = theta*k_1;
	else
		if abs(theta)<phi_2 then
			p.e = sign(theta)*(T_1 + (abs(theta)-phi_1)*k_2);
		else
			p.e = sign(theta)*(T_2 + (abs(theta)-phi_2)*k_3);
		end;
	end;implementation_end;
      plug tau_in 48 88;
      plug tau_out 488 88;
      OneJunction 128 88
       description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\OneJunction.emx</LibraryPath>
  <TimeStamp>2011-11-29 16:17:51</TimeStamp>
</Description>
</Information>';
       knot OneJunction
        ports
         power knot duplicatable none p [1];
         signal knot out flow [1];
        restrictions
         causality constraint one_out p;
       end;
       icon bg ellipse
        figures
         text '1' 128 88 color 0 18 bold;
       end;
       implementation eq
equations
	sum (direct (p.e)) = 0;
	equal (collect (p.f));
	flow = first (p.f);
implementation_end;
      OneJunction1 400 88
       description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\OneJunction.emx</LibraryPath>
