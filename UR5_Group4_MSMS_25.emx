parameters
	real global rG[3];
	
variables 
	real global alpha;
	real global a;
	real global d;
	real r_AG[3];
	real r_GA[3];
	real R_AG[3,3];
	real r[3,3];
	
initialequations
  r_AG = [ rG[1]+a; 
          cos(alpha)*rG[2]-sin(alpha)*rG[3]; 
          sin(alpha)*rG[2]+cos(alpha)*rG[3]+d];
 
  R_AG = [  1,      0,       0;
          0,cos(alpha), -sin(alpha);
          0, sin(alpha), cos(alpha)];

  r_GA = -transpose(R_AG)*r_AG;

  r = skew(r_GA);

equations					
	p1.e = transpose (r) * p2.e;
	p2.f = r * p1.f;
implementation_end;
