     connections
      FlowSensor1\flow -> Integrate\input;
      FlowSensor1\p2 => ZeroJunction\p;
      Integrate\R_theta_v -> R_theta_transpose\R_theta;
      Integrate\R_theta_w -> R_theta_trans1\R_theta;
      Integrate\theta_out -> theta_out;
      PowerDemux2\output1 => ZeroJunction1\p;
      PowerDemux2\output2 => ZeroJunction2\p;
      PowerDemux2\output3 => ZeroJunction\p;
      PowerMux1\output => R_theta_trans1\p1;
      R_theta_trans1\p2 => w_out;
      R_theta_transpose\p2 => v_out;
      theta_dot => FlowSensor1\p1;
      v_in |=> ZeroJunction4\p user;
      w_in => PowerDemux2\input;
      ZeroJunction\p => PowerMux1\input3;
      ZeroJunction1\p => C_wx\input;
      ZeroJunction1\p => PowerMux1\input1;
      ZeroJunction2\p => C_wy\input;
      ZeroJunction2\p => PowerMux1\input2;
      ZeroJunction4\p => R_theta_transpose\p1;
      ZeroJunction4\p |=> C_v\input user;
     end;
    implementation_end;
