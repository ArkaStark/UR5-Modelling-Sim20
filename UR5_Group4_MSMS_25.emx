      r_GA 376 216
       description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Bond Graph\3D\TF-3.emx</LibraryPath>
  <TimeStamp>2007-9-25 12:11:35</TimeStamp>
</Description>';
       type 'TF-3'
        ports
         power in p1 [3,1];
         power out p2 [3,1];
        restrictions
         causality constraint not_equal p1 p2;
       end;
       icon bg ellipse right
        figures
         text 'TF' 376 216 color 0 18 bold;
       end;
       implementation eq
parameters
	real global rG[3];
	
variables 
	real global alpha;
	real global a;
	real global d;
	real r_AG[3];
	real r_GA[3];
	real R_AG[3,3];
	real r[3,3];
	
initialequations
  r_AG = [ rG[1]+a; 
          cos(alpha)*rG[2]-sin(alpha)*rG[3]; 
          sin(alpha)*rG[2]+cos(alpha)*rG[3]+d];
 
  R_AG = [  1,      0,       0;
          0,cos(alpha), -sin(alpha);
          0, sin(alpha), cos(alpha)];

  r_GA = -transpose(R_AG)*r_AG;

  r = skew(r_GA);

equations					
	p1.e = transpose (r) * p2.e;
	p2.f = r * p1.f;
implementation_end;
      r_GB 656 216
       description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Bond Graph\3D\TF-3.emx</LibraryPath>
