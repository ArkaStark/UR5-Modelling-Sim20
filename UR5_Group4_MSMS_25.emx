      Integrate 584 208
       description '<Information>
 <Description>
    <Version>4.3</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Signal\Block Diagram\Integrate.emx</LibraryPath>
  <TimeStamp>2013-3-8 14:47:42</TimeStamp>
</Description>
</Information>';
       type Integrate
        ports
         signal in input;
         signal out theta_out;
         signal out R_theta_w [3,3];
         signal out R_theta_v [3,3];
       end;
       icon bg bottom
        figures
         rectangle 568 192 600 224 color 0 fill 15132390;
         text '∫' 584 208.3 color 16711680 'Lucida Sans' 21 italic;
       end;
       implementation eq
parameters
	real initial = 0;		// initial value
	
equations
	//theta_out = (int (input, initial)) mod pi;
	theta_out = int (input, initial);
	R_theta_w = [cos(theta_out),sin(theta_out), 0.0;
					-sin(theta_out), cos(theta_out), 0;
						0.0, 				0.0, 			1.0];
	R_theta_v = R_theta_w;
     
implementation_end;
      plug theta_dot 328 208;
      plug w_out 768 128;
