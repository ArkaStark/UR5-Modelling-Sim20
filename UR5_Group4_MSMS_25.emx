   PID1 152 360
    description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Signal\Control\PID Control\Continuous\PID.emx</LibraryPath><TimeStamp>2008-1-17 10:49:30</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type PID
     ports
      signal in error;
      signal out output;
    end;
    icon bg bottom
     figures
      rectangle 136 344 168 376 color 0 fill 15132390;
      text 'PID' 152 359.5 color 16711680 18 bold;
    end;
    implementation eq
parameters
	real local_kp;			// Proportional gain
	real local_tauD;		// Derivative time constant: tauD > 0
	real local_beta;		// Tameness constant: 0 < beta << 1
	real local_tauI;		// Integral time constant: tauI > 0
	
	real global Kp[6];			// Proportional gain
	real global tau_d[6];		// Derivative time constant: tauD > 0
	real global beta[6];		// Tameness constant: 0 < beta << 1
	real global tau_i[6];		// Integral time constant: tauI > 0
	
initialequations
	local_kp = Kp[1];
	local_tauD = tau_d[1];
	local_beta = beta[1];
	local_tauI = tau_i[1];
	
variables
	real pdout, pdrate, pdstate;
	real pirate, pistate;
equations
	pdrate = (local_kp * error - pdout) / (local_beta * local_tauD);
	pdstate = int (pdrate);
	pdout = pdstate + (local_kp * error / local_beta);
	pirate = pdout / local_tauI;
	pistate = int (pirate);
	output = pistate + pdout;
      
implementation_end;
