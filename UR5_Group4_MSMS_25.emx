   Link_2 440 112
    description '<Information><Description><Version>4.0</Version><LibraryPath>Template\Submodel-Graphical.emx</LibraryPath><IsMainModel>1</IsMainModel><KeepParameterValues>True</KeepParameterValues><TimeStamp>2007-11-1 22:32:34</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description><Attributes><GlobalRelations>parameters
	real m = 8.393; 
	real J[3,3] = [0.0149, 		0.0,			0.0;
					   0.0, 	   	0.3564,   	0.0; 
					   0.0, 	    	0.0,	 	   0.3553];
	real rG[3] = [0.2125; 0.0; 0.11336]; 

	real global alpha_DH[6];
	real global d_DH[6];
	real global a_DH[6];


variables 
	//DENAVIT-HARTENBERG
	real a ;
	real alpha; 
	real d;

initialequations
	alpha = alpha_DH[2]; 
	a = a_DH[2];
	d = d_DH[2];</GlobalRelations></Attributes></Information>';
    type 'Submodel-Graphical'
     ports
      power in w_A [3,1];
      power in v_A [3,1];
      power out w_B [3,1];
      power out v_B [3,1];
    end;
    icon bg
     figures
      rectangle 408 96 472 128 color 0 fill 15132390;
      text 'name' 440 112 color 0 16;
    end;
    implementation bg
     submodels
      Euler_EQ 568 398
       description '<Information><Description><Version>4.0</Version><LibraryPath>Template\Submodel-Equation.emx</LibraryPath><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><TimeStamp>2007-11-1 22:32:1</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description></Information>';
       type 'Submodel-Equation'
        ports
         power in Tran [3,1];
         power in Rot [3,1];
         signal out R_OG [3,3];
         signal out P_OG [3,1];
         signal out p_og_anim [3,1];
       end;
       implementation eq
parameters
	real global m;
	real global J[3, 3];
	real global rG[3, 1];
	
variables
	real omega[3,1], v[3,1];
	real p[3,1], h[3,1]; 
	real R_OG_0[3,3];
	real P_OG_0[3,1];
		
	real global H2[4,4];
		
initialequations
	R_OG_0 = H2[1:3,1:3];
	P_OG_0 = R_OG_0*rG + H2[1:3,4]; 
	/* Position vector of point G relative to origin O in reference frame 0
 R_OG_0 * rG rotates the CoM position from link frame to base frame
 H1[1:3,4] gives the origin of the link frame in the base frame
 Their sum gives the absolute position of G in base frame 0 (P_OG_0)*/

equations 
	omega = Rot.f; 
	v = Tran.f; 
	//Euler equations
	p = int(Tran.e - skew(omega)*p); 
	h = int(Rot.e - skew(omega)*h);
	
	//compute R_OG
	R_OG = int(R_OG * skew(omega), R_OG_0);
	P_OG = int(R_OG * v, P_OG_0); 
	p_og_anim = P_OG * 5;
	
	
	Tran.f = p/m; 
	Rot.f = inverse(J)*h; 
	
implementation_end;
      gravity 264 408
       description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\3D\Se-3.emx</LibraryPath><TimeStamp>2007-9-25 12:11:25</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
