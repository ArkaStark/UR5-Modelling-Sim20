  <Sidops><![CDATA[model 128 184
 description '<Information>
  <Description>
    <Version>5.1</Version>
    <IsMainModel>0</IsMainModel>
    <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>D:\Study\SEM 3\MSMS\msms\myworks\UR5_Group4_MSMS_25_HD_GComp.emx</LibraryPath>
    <TimeStamp>2025-6-13 13:45:18</TimeStamp>
  </Description>
  <Attributes>
    <GlobalRelations>parameters

	real gravity_yes = 1;


	//DENAVIT HARTENBERG PARAMETERS 
	real theta_init[6] = [0;0;0;0;0;0];
	real alpha_DH[6] = [pi/2; 0; 0; pi/2; -pi/2; 0];
	real d_DH[6] = [0.089159; 0; 0; 0.10915; 0.09465; 0.0823];
	real a_DH[6] = [0; -0.425; -0.39225; 0; 0; 0];
	
	// JOINT REFERENCE ANGLES
	real theta_ref[6] = [pi/4; -pi/3; -pi/2; -2*pi/3; pi/2; pi/6];

	// PID TUNING PARAMETERS 
	// PID TUNING PARAMETERS (Tuned)
	real Kp[6] = [1/(-750); 1/(-800); 3/(-600); 7/(-400); 10/(-600); 3/(-200)];          // Proportional gains
	real tau_d[6] = [3000; 6000; 2000; 600; 600; 200];         // Derivative time constants (increased damping)
	real beta[6] = [0.01; 0.01; 0.01; 0.01; 0.01; 0.01];     // Slightly more derivative filtering
	real tau_i[6] = [10000; 100000; 10000; 10000000000; 10000000; 1000000];          // Faster integral action for first joints only


variables

	real H1[4,4];
	real H2[4,4];
	real H3[4,4];
	real H4[4,4];
	real H5[4,4];
	real H6[4,4];

initialequations

	H1 = [
	    cos(theta_init[1]), 		-sin(theta_init[1])*cos(alpha_DH[1]), 		sin(theta_init[1])*sin(alpha_DH[1]), 		a_DH[1]*cos(theta_init[1]);
	    sin(theta_init[1]), 		cos(theta_init[1])*cos(alpha_DH[1]),		-cos(theta_init[1])*sin(alpha_DH[1]),		a_DH[1]*sin(theta_init[1]);
	    0.0, 							sin(alpha_DH[1]), 								cos(alpha_DH[1]),									d_DH[1];
	    0.0, 							0.0, 													0.0, 													1.0
	];
	
	H2 = H1 * [
	    cos(theta_init[2]), 		-sin(theta_init[2])*cos(alpha_DH[2]), 		sin(theta_init[2])*sin(alpha_DH[2]), 		a_DH[2]*cos(theta_init[2]);
	    sin(theta_init[2]), 		cos(theta_init[2])*cos(alpha_DH[2]), 		-cos(theta_init[2])*sin(alpha_DH[2]), 		a_DH[2]*sin(theta_init[2]);
	    0.0, 							sin(alpha_DH[2]), 								cos(alpha_DH[2]), 								d_DH[2];
	    0.0, 							0.0, 													0.0, 													1.0
	];
	
	H3 = H2 * [
	    cos(theta_init[3]), 		-sin(theta_init[3])*cos(alpha_DH[3]), 		sin(theta_init[3])*sin(alpha_DH[3]), 		a_DH[3]*cos(theta_init[3]);
	    sin(theta_init[3]), 		cos(theta_init[3])*cos(alpha_DH[3]), 		-cos(theta_init[3])*sin(alpha_DH[3]), 		a_DH[3]*sin(theta_init[3]);
	    0.0, 							sin(alpha_DH[3]), 								cos(alpha_DH[3]), 								d_DH[3];
	    0.0, 							0.0, 													0.0, 													1.0
	];
	
	H4 = H3 * [
	    cos(theta_init[4]), 		-sin(theta_init[4])*cos(alpha_DH[4]), 		sin(theta_init[4])*sin(alpha_DH[4]), 		a_DH[4]*cos(theta_init[4]);
	    sin(theta_init[4]), 		cos(theta_init[4])*cos(alpha_DH[4]), 		-cos(theta_init[4])*sin(alpha_DH[4]), 		a_DH[4]*sin(theta_init[4]);
	    0.0, 							sin(alpha_DH[4]), 								cos(alpha_DH[4]), 								d_DH[4];
	    0.0, 							0.0, 													0.0, 													1.0
	];
	
	H5 = H4 * [
	    cos(theta_init[5]), 		-sin(theta_init[5])*cos(alpha_DH[5]), 		sin(theta_init[5])*sin(alpha_DH[5]), 		a_DH[5]*cos(theta_init[5]);
	    sin(theta_init[5]), 		cos(theta_init[5])*cos(alpha_DH[5]), 		-cos(theta_init[5])*sin(alpha_DH[5]), 		a_DH[5]*sin(theta_init[5]);
	    0.0, 							sin(alpha_DH[5]), 								cos(alpha_DH[5]), 								d_DH[5];
	    0.0, 							0.0, 													0.0, 													1.0
	];
	
	H6 = H5 * [
	    cos(theta_init[6]), 		-sin(theta_init[6])*cos(alpha_DH[6]), 		sin(theta_init[6])*sin(alpha_DH[6]), 		a_DH[6]*cos(theta_init[6]);
	    sin(theta_init[6]), 		cos(theta_init[6])*cos(alpha_DH[6]), 		-cos(theta_init[6])*sin(alpha_DH[6]), 		a_DH[6]*sin(theta_init[6]);
	    0.0, 							sin(alpha_DH[6]), 								cos(alpha_DH[6]), 								d_DH[6];
	    0.0, 							0.0, 													0.0, 													1.0
	];</GlobalRelations>
  </Attributes>
</Information>';
 type Mainmodel
 end;
