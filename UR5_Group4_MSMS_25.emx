      K_f 352 152
       description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\C.emx</LibraryPath><TimeStamp>2011-11-29 15:58:35</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type C
        ports
         power in p;
         signal out state;
        restrictions
         causality preferred out p;
       end;
       icon bg ellipse bottom
        figures
         text 'C' 352 152 color 0 18 bold;
       end;
       implementation eq
parameters
	real k_1 = 16000;
	real k_2 = 25000;
	real k_3 = 29000;
	real T_1 = 7;
	real T_2 = 25;
	
variables
	real phi_1;
	real phi_2;
	real theta;	

equations
	phi_1 = T_1/k_1;
	phi_2 = phi_1 + (T_2-T_1)/k_2;
	theta = int(p.f);
	
	if abs(theta)<phi_1 then
		p.e = theta*k_1;
	else
		if abs(theta)<phi_2 then
			p.e = sign(theta)*(T_1 + (abs(theta)-phi_1)*k_2);
		else
			p.e = sign(theta)*(T_2 + (abs(theta)-phi_2)*k_3);
		end;
	end;implementation_end;
