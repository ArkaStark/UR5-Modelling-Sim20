       type 'MTF-3'
        ports
         power in p1 [3,1];
         power out p2 [3,1];
         signal in R_theta [3,3];
        restrictions
         causality constraint not_equal p1 p2;
       end;
       icon bg ellipse
        figures
         text 'MTF' 677.5 157.4 color 0 18 bold;
       end;
       implementation eq

equations //transpose matrix already
	p1.e = transpose(R_theta) * p2.e;
	p2.f = R_theta * p1.f;
implementation_end;
