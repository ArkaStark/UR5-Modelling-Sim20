       end;
       icon bg ellipse bottom
        figures
         text 'Se' 264 408 color 0 18 bold;
       end;
       implementation eq
parameters 
	real global m;
	real global gravity_yes;
variables
	real flow [3,1];
	real effort[3,1];


initialequations
	if gravity_yes == 1 then 
		effort= [0.0; 0.0; -m * 9.81];
	else
		effort= [0.0; 0.0; 0.0];
	end;

equations
	p.e = effort; 
	flow = p.f;implementation_end;
