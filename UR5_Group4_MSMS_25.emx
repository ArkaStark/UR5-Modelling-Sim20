	pdrate = (local_kp * error - pdout) / (local_beta * local_tauD);
	pdstate = int (pdrate);
	pdout = pdstate + (local_kp * error / local_beta);
	pirate = pdout / local_tauI;
	pistate = int (pirate);
	output = pistate + pdout;
      
implementation_end;
