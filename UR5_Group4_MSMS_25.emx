       type 'TF-3'
        ports
         power in p1 [3,1];
         power out p2 [3,1];
        restrictions
         causality constraint not_equal p1 p2;
       end;
       icon bg ellipse right
        figures
         text 'TF' 656 216 color 0 18 bold;
       end;
       implementation eq
parameters
	real global rG[3];
	
variables 
	real r_GB[3];
	real r[3,3];

initialequations 
	
	r_GB = [-rG[1]; 
          -rG[2]; 
          -rG[3]];
	
	r = skew(r_GB);
	
equations					
	p1.f = (r) * p2.f;
	p2.e = transpose(r) * p1.e;
implementation_end;
